{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "distro-m",
    "version": "0.1.0",
    "identifier": "DistroMusic",
    "build": {
        "beforeDevCommand": "pnpm dev",
        "devUrl": "http://localhost:5173",
        "beforeBuildCommand": "pnpm build",
        "frontendDist": "../dist"
    },
    "app": {
        "windows": [
            {
                "title": "Distro Music",
                "width": 1000,
                "height": 800,
                "decorations": false,
                "maximized": true,
                "resizable": false,
                "fullscreen": false,
                "visible": true
            }
        ],
        "security": {
            "csp": null,
            "assetProtocol": {
                "scope": [
                    "**"
                ],
                "enable": true
            }
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.ico"
        ]
    }
}